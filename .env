# ─────────────────────────────────────────────────────────────────────────────
# CamionSuf Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
# Obtenez ces valeurs sur https://developers.facebook.com/apps/
# → votre app → WhatsApp → Configuration API

# Token d'accès permanent (ou temporaire pour les tests)
WHATSAPP_ACCESS_TOKEN=

# ID de votre numéro téléphonique WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Clé secrète partagée entre Vercel (api/notify.js) et ce backend
# Générez une chaîne aléatoire longue, ex: openssl rand -hex 32
TRACKING_SECRET=

TOKEN_SECRET=

# ── Optionnel : URL de la plateforme (utilisée dans les messages WhatsApp) ───
FRONTEND_URL=https://camionsuf.vercel.app
