# ─────────────────────────────────────────────────────────────────────────────
# CamionSuf Backend — Variables d'environnement
# 1. Copiez ce fichier :  cp .env.example .env
# 2. Remplissez chaque valeur ci-dessous
# 3. Ne commitez JAMAIS le fichier .env (il est dans .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
# Obtenez ces valeurs sur https://developers.facebook.com/apps/
#   → votre app → WhatsApp → Configuration API

# Token d'accès permanent (System User Token recommandé en production)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# ID de votre numéro téléphonique WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Clé secrète partagée entre Vercel (api/notify.js) et ce backend Flask.
# Générez une valeur aléatoire forte, ex: openssl rand -hex 32
TRACKING_SECRET=your_strong_random_secret_here

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL du frontend (utilisée dans les liens de suivi WhatsApp)
FRONTEND_URL=https://camionsuf.vercel.app
